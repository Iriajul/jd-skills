# ─── FastAPI ──────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<64-char-hex-string-no-special-characters>

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# In Docker: DB_HOST=db  (matches the service name in docker-compose)
# Local dev:  DB_HOST=127.0.0.1
DB_NAME=atsfriendly
DB_USER=postgres
DB_PASSWORD=<your-db-password>
DB_HOST=db
DB_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────────────
# In Docker: redis://redis:6379/0
# Local dev:  redis://127.0.0.1:6379/0
REDIS_URL=redis://redis:6379/0

# ─── Qdrant Vector DB ─────────────────────────────────────────────────────────
# Local Docker: leave QDRANT_API_KEY empty (no auth for self-hosted)
# Qdrant Cloud: set both URL and API key
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ─── LLM Providers ────────────────────────────────────────────────────────────
# OpenAI → platform.openai.com/api-keys
OPENAI_API_KEY=<your-openai-api-key>

# Tavily Search API → app.tavily.com (job discovery)
TAVILY_API_KEY=<your-tavily-api-key>

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated. Production: set to your real frontend domain.
# Must be valid JSON array — pydantic-settings v2 parses list fields as JSON
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
